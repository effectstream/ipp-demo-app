{
  "transforms": [
    {
      "mode": "sql",
      "include": "**/*.sql",
      "emitTemplate": "{{dir}}/{{name}}.queries.ts"
    }
  ],
  "srcDir": "./sql",
  "failOnError": false,
  "camelCaseColumnNames": false,
  "db": {
    "dbName": "postgres",
    "user": "postgres",
    "password": "postgres",
    "host": "localhost",
    "port": 5432,
    "ssl": false
  },
  "maxWorkerThreads": 1
}
