# Copy to .env and fill in. .env is gitignored.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
PORT=3334
# Chain adapter: local (no-op, default) | cardano (anchor in tx metadata on the
# EffectStream/yaci devnet) | midnight (legacy).
CHAIN=local
# Cardano adapter (CHAIN=cardano). Defaults target the local EffectStream
# devnet brought up by `cd cardano && bun run dev` (yaci + dolos + sync node).
# CARDANO_DOLOS_URL=http://localhost:3000
# CARDANO_YACI_URL=http://localhost:10000
# CARDANO_PGLITE_URL=postgres://postgres:postgres@localhost:5432/postgres
# CARDANO_WALLET_SEED=   # 24-word seed; omit to generate + faucet-fund a dev wallet
# Secret used to HMAC patient passcodes before storing them (so a DB leak
# doesn't expose lookup codes). Use a long random value, e.g. `openssl rand -hex 32`.
# Must stay stable - changing it invalidates every stored passcode hash.
PASSCODE_SECRET=replace-with-a-long-random-secret
