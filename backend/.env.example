# Copy to .env and fill in. .env is gitignored.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
PORT=3334
CHAIN=local
# Secret used to HMAC patient passcodes before storing them (so a DB leak
# doesn't expose lookup codes). Use a long random value, e.g. `openssl rand -hex 32`.
# Must stay stable — changing it invalidates every stored passcode hash.
PASSCODE_SECRET=replace-with-a-long-random-secret
